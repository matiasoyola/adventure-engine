# ─────────────────────────────────────────────────────────────────
# Adventure Engine — variables de entorno
# Copia este archivo a .env.production y rellena los valores reales.
# NUNCA subas .env.production a git.
# ─────────────────────────────────────────────────────────────────

# Node environment
NODE_ENV=production

# Puerto en el que escucha Next.js internamente.
# Nginx hace proxy desde el puerto 80/443 hacia este puerto.
# No lo expongas directamente en el firewall.
PORT=3000

# Ruta absoluta a la base de datos SQLite en el VPS.
# El directorio /var/www/adventure-engine/data debe existir y
# tener permisos de escritura para el usuario que corre PM2.
DATABASE_URL=/var/www/adventure-engine/data/adventure.db

# (v2) Si migras a Postgres, cambia este valor por la connection string:
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/adventure
